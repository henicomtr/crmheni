# Bu dosyayı kopyalayıp .env olarak kaydet: cp .env.example .env
# .env dosyasını asla git'e commit etme!

# ── Veritabanı ─────────────────────────────────────────────
# Local geliştirme (SQLite):
# DATABASE_URL=sqlite:///./heni.db
#
# Production (PostgreSQL — Coolify'dan alacaksın):
DATABASE_URL=postgresql://heni_user:GUCLU_SIFRE@localhost:5432/heni_db

# ── Güvenlik ───────────────────────────────────────────────
# Güçlü bir secret üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=buraya-cok-uzun-ve-rastgele-bir-string-yaz

# ── Ortam ──────────────────────────────────────────────────
ENVIRONMENT=production
